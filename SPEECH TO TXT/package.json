{
  "name": "ivr-complaint-system",
  "version": "1.0.0",
  "description": "Twilio-only IVR complaint registration backend",
  "main": "server.js",
  "scripts": {
    "free:3001": "node scripts/kill-port.js 3001",
    "dev:clean": "npm run free:3001 && nodemon server.js",
    "start": "npm run free:3001 && node server.js",
    "dev": "npm run dev:clean",
    "test:verify-call": "node scripts/test-verification-call.js",
    "trigger:ivr": "node scripts/trigger-ivr-call.js",
    "tunnel": "npx localtunnel --port 3001 --subdomain hp-tark-ivr-3001"
  },
  "keywords": [
    "twilio",
    "ivr",
    "express"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "axios": "^1.8.4",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "ngrok": "^5.0.0-beta.2",
    "twilio": "^5.4.1"
  },
  "devDependencies": {
    "nodemon": "^3.1.9"
  }
}
